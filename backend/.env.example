# ── Ambience Studio — Backend Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ambience_studio

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_ambience2025
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
